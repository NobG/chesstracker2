[Unit]
Description=chesstracker Java service example
After=network.target postgresql.service

[Service]
User=chesstracker
Group=chesstracker
WorkingDirectory=/opt/chesstracker
EnvironmentFile=/opt/chesstracker/env
ExecStart=/usr/bin/java -jar /opt/chesstracker/chesstracker.jar
Restart=on-failure
RestartSec=5
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target
